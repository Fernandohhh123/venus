bits 16
org 0

cli
mov ax, 0x1000
mov ds, ax
mov ax, 0x1000
mov es, ax
mov ax, 0x1000
mov ss, ax
mov sp, 0xFFFF
sti

jmp start

;system info
OS_name db "venus", 0
OS_version db "0.1", 0
prompt db "> ", 0

start:
	cli

	call .init_video

	mov bl, 00000111b
	call .set_text_color

	mov bl, 00000010b
	call .set_text_color

	mov bx, msgEnterMainLoop
	call .print_str

	mov bl, 01010000b ;magenta
	call .set_text_color
	mov bx, OS_name
	call .print_str

	jmp .main_loop

;-------------------------
;-------------------------

.main_loop:

	;sti

	; call .clean_screen
	; x , y
	; bh, bl

	mov bl, 00000000b
	mov bl, prompt
	call .putchar

	hlt

	jmp .main_loop

.syscall_dispatcher:

ret

%include "src/kernel/video.s"
%include "src/kernel/ivt.s"

msgEnterMainLoop db "Enter to main loop", 0x0A, 0x0D, 0

msgEndl db 0xa, 0xd, 0
